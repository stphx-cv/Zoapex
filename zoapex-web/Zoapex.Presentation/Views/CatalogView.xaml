<Page x:Class="Zoapex.Presentation.Views.CatalogView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Product Catalog">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ====================================================== -->
        <!-- PANEL IZQUIERDO: lista de productos                     -->
        <!-- ====================================================== -->
        <DockPanel Grid.Column="0" Margin="0,0,14,0">

            <!-- Título -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Product Catalog" FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,12"/>

            <!-- Barra de filtro -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Filter:" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                <TextBox x:Name="txtFilter" FontSize="13" Padding="6,4"
                         TextChanged="TxtFilter_TextChanged"
                         ToolTip="Type to filter by name or code"/>
            </DockPanel>

            <!-- Botones de acción CRUD -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="New" Style="{StaticResource ActionButton}"
                        Background="#3498DB" Click="BtnNew_Click"/>
                <Button Content="Edit" Style="{StaticResource ActionButton}"
                        Background="#F39C12" Click="BtnEdit_Click"/>
                <Button Content="Delete" Style="{StaticResource ActionButton}"
                        Background="#E74C3C" Click="BtnDelete_Click"/>
                <Button Content="Refresh" Style="{StaticResource ActionButton}"
                        Background="#7F8C8D" Click="BtnRefresh_Click"/>
                <TextBlock x:Name="lblStatus" VerticalAlignment="Center"
                           FontSize="12" Foreground="#666" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- DataGrid de productos -->
            <DataGrid x:Name="dgProducts"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" CanUserSortColumns="True"
                      SelectionChanged="DgProducts_SelectionChanged"
                      AlternatingRowBackground="#F8F9FA" RowHeight="30"
                      FontSize="13" GridLinesVisibility="Horizontal"
                      BorderBrush="#DDD" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code"     Binding="{Binding code}"          Width="70"/>
                    <DataGridTextColumn Header="Name"     Binding="{Binding name}"          Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding category_name}" Width="110"/>
                    <DataGridTextColumn Header="Price"    Width="75">
                        <DataGridTextColumn.Binding>
                            <Binding Path="price" StringFormat="S/. {0:N2}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Stock"    Binding="{Binding stock}"     Width="55"/>
                    <DataGridTextColumn Header="Min"      Binding="{Binding min_stock}" Width="45"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- ====================================================== -->
        <!-- PANEL DERECHO: formulario Nuevo / Editar               -->
        <!-- ====================================================== -->
        <Border Grid.Column="1" Background="#F5F6FA" CornerRadius="8"
                Padding="16" BorderBrush="#DDD" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="lblFormTitle"
                           Text="New Product" FontSize="16" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,12"/>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Content="Save" Width="110" Background="#27AE60"
                            Style="{StaticResource ActionButton}" Click="BtnSave_Click"/>
                    <Button Content="Cancel" Width="110" Background="#95A5A6"
                            Style="{StaticResource ActionButton}" Click="BtnCancel_Click"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="formPanel" IsEnabled="False">
                        <TextBlock Text="Name *" Style="{StaticResource FormLabel}"/>
                        <TextBox  x:Name="txtName" Style="{StaticResource FormInput}" MaxLength="80"/>

                        <TextBlock Text="Description" Style="{StaticResource FormLabel}"/>
                        <TextBox  x:Name="txtDescription" Style="{StaticResource FormInput}"
                                  MaxLength="200" Height="60" AcceptsReturn="True"
                                  TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Price *" Style="{StaticResource FormLabel}"/>
                        <TextBox  x:Name="txtPrice" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="Stock *" Style="{StaticResource FormLabel}"/>
                        <TextBox  x:Name="txtStock" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="Min Stock" Style="{StaticResource FormLabel}"/>
                        <TextBox  x:Name="txtMinStock" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="Category *" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="cmbCategory" FontSize="13" Padding="4"
                                  DisplayMemberPath="name"
                                  SelectedValuePath="category_id"/>

                        <TextBlock Text="Image URL" Style="{StaticResource FormLabel}"/>
                        <TextBox  x:Name="txtImageUrl" Style="{StaticResource FormInput}"
                                  MaxLength="300"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>
