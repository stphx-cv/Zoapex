@using Zoapex.Web.Data
@inject IConfiguration Config
@{
    var titulo = ViewData["Title"] as string ?? "Zoapex";
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var customerName = User.Identity?.Name;
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var warnMin = Config.GetValue("Security:SessionWarningMinutes", 25);
    var timeoutMin = Config.GetValue("Security:SessionTimeoutMinutes", 30);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@titulo - Zoapex</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="brand" asp-page="/Index">
                <span class="brand-icon">🐾</span>
                <span class="brand-text">Zoapex</span>
            </a>

            <nav class="main-nav">
                <a asp-page="/Index" class="@(currentPage == "/Index" ? "active" : "")">Inicio</a>
                <a asp-page="/Catalog" class="@(currentPage == "/Catalog" ? "active" : "")">Catálogo</a>
                <a asp-page="/Cart" class="@(currentPage == "/Cart" ? "active" : "")">Carrito</a>
                @if (isLoggedIn)
                {
                    <a asp-page="/Orders" class="@(currentPage == "/Orders" ? "active" : "")">Mis pedidos</a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="/SalesReport" class="@(currentPage == "/SalesReport" ? "active" : "")">Reporte</a>
                }
            </nav>

            <div class="header-actions">
                @if (isLoggedIn)
                {
                    <span class="user-greeting">Hola, @customerName</span>
                    <form method="post" asp-page="/Account/Logout" class="inline-form">
                        <button type="submit" class="btn btn-outline btn-sm">Salir</button>
                    </form>
                }
                else
                {
                    <a asp-page="/Account/Login" class="btn btn-outline btn-sm">Iniciar sesión</a>
                    <a asp-page="/Account/Register" class="btn btn-primary btn-sm">Registrarse</a>
                }
            </div>
        </div>
    </header>

    <main class="site-main container" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-inner">
            <p><strong>Zoapex</strong> — Tienda de mascotas</p>
            <p class="footer-meta">Desarrollo de Aplicaciones Básico · Stephano Camarena Villa</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    @if (isLoggedIn)
    {
        <script>
            // Caducidad de sesión por inactividad (parte cliente).
            // La cookie expira en el servidor; aquí avisamos y luego cerramos sesión.
            (function () {
                const avisoMs = @(warnMin) * 60 * 1000;
                const cierreMs = @(timeoutMin) * 60 * 1000;
                let avisoTimer, cierreTimer, avisado = false;

                function programar() {
                    clearTimeout(avisoTimer);
                    clearTimeout(cierreTimer);
                    avisado = false;
                    avisoTimer = setTimeout(function () {
                        avisado = true;
                        alert("Tu sesión está por expirar por inactividad.");
                    }, avisoMs);
                    cierreTimer = setTimeout(function () {
                        window.location = "/Account/Logout"; // cierra sesión y vuelve al login
                    }, cierreMs);
                }

                // Cualquier actividad del usuario reinicia el conteo
                ["mousemove", "keydown", "scroll", "click"].forEach(function (evt) {
                    document.addEventListener(evt, function () {
                        if (!avisado) programar();
                    }, { passive: true });
                });

                programar();
            })();
        </script>
    }
</body>
</html>
