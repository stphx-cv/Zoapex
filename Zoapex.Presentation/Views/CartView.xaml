<Page x:Class="Zoapex.Presentation.Views.CartView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Shopping Cart">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="240"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Shopping Cart" FontSize="20" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,12"/>

        <!-- ====================================================== -->
        <!-- Catálogo de productos disponibles (fila superior)      -->
        <!-- ====================================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de productos del catálogo -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top" Text="Available Products"
                           FontSize="14" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>
                <DataGrid x:Name="dgAvailable"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          AlternatingRowBackground="#F8F9FA" RowHeight="28" FontSize="13"
                          GridLinesVisibility="Horizontal" BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code"     Binding="{Binding code}"          Width="70"/>
                        <DataGridTextColumn Header="Product"  Binding="{Binding name}"          Width="*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding category_name}" Width="100"/>
                        <DataGridTextColumn Header="Price"    Width="80">
                            <DataGridTextColumn.Binding>
                                <Binding Path="price" StringFormat="S/. {0:N2}"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Stock"    Binding="{Binding stock}"         Width="55"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Panel "Add to Cart" -->
            <Border Grid.Column="1" Background="#F5F6FA" CornerRadius="8"
                    Padding="14" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Add to Cart" FontSize="14" FontWeight="SemiBold"
                               Foreground="#2C3E50" Margin="0,0,0,12"/>

                    <TextBlock Text="Quantity:" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtQty" Style="{StaticResource FormInput}" Text="1"/>

                    <Button Content="Add to Cart" Background="#3498DB"
                            Style="{StaticResource ActionButton}"
                            Margin="0,14,0,0" HorizontalAlignment="Stretch"
                            Click="BtnAddToCart_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Separador -->
        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="#DDD"/>

        <!-- ====================================================== -->
        <!-- Carrito (fila inferior)                                 -->
        <!-- ====================================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Items del carrito -->
            <DockPanel Grid.Column="0" Margin="0,8,12,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock Text="Cart Items" DockPanel.Dock="Left"
                               FontSize="14" FontWeight="SemiBold" Foreground="#555"/>
                    <Button Content="Remove" DockPanel.Dock="Right"
                            Style="{StaticResource ActionButton}"
                            Background="#E74C3C" Click="BtnRemove_Click"/>
                </DockPanel>
                <DataGrid x:Name="dgCart"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          AlternatingRowBackground="#FFF9F0" RowHeight="28" FontSize="13"
                          GridLinesVisibility="Horizontal" BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product"    Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Unit Price" Width="90">
                            <DataGridTextColumn.Binding>
                                <Binding Path="UnitPrice" StringFormat="S/. {0:N2}"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Qty"        Binding="{Binding Quantity}"    Width="50"/>
                        <DataGridTextColumn Header="Subtotal"   Width="90">
                            <DataGridTextColumn.Binding>
                                <Binding Path="Subtotal" StringFormat="S/. {0:N2}"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Totales y registro de venta -->
            <Border Grid.Column="1" Background="#F5F6FA" CornerRadius="8"
                    Padding="14" Margin="0,8,0,0"
                    BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Order Summary" FontSize="14" FontWeight="SemiBold"
                               Foreground="#2C3E50" Margin="0,0,0,12"/>

                    <DockPanel Margin="0,4">
                        <TextBlock Text="Subtotal:" DockPanel.Dock="Left" FontSize="13"/>
                        <TextBlock x:Name="lblSubtotal" Text="S/. 0.00"
                                   DockPanel.Dock="Right" FontSize="13" TextAlignment="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="IGV (18%):" DockPanel.Dock="Left" FontSize="13"/>
                        <TextBlock x:Name="lblTax" Text="S/. 0.00"
                                   DockPanel.Dock="Right" FontSize="13" TextAlignment="Right"/>
                    </DockPanel>
                    <Separator Margin="0,6"/>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="TOTAL:" DockPanel.Dock="Left"
                                   FontSize="15" FontWeight="Bold"/>
                        <TextBlock x:Name="lblTotal" Text="S/. 0.00"
                                   DockPanel.Dock="Right" FontSize="15" FontWeight="Bold"
                                   Foreground="#27AE60" TextAlignment="Right"/>
                    </DockPanel>

                    <Button Content="Register Sale" Background="#27AE60"
                            Style="{StaticResource ActionButton}"
                            Margin="0,16,0,4" HorizontalAlignment="Stretch"
                            FontWeight="Bold"
                            Click="BtnRegisterSale_Click"/>
                    <Button Content="Clear Cart" Background="#E74C3C"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Stretch"
                            Click="BtnClearCart_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
